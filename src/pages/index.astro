---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE } from '../site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const projects = await getCollection('projects');
const featured = projects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6);
---

<BaseLayout>
  <!-- Hero -->
  <section class="relative border-b border-[var(--rule)]">
    <div class="bg-graph pointer-events-none absolute inset-0 opacity-50" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-5xl px-5 py-20 sm:py-28">
      <div class="flex flex-col-reverse items-center gap-12 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex-1">
          <h1 class="max-w-2xl text-4xl leading-tight sm:text-6xl">
            Digital projects, technical writing and creative tools, made with precision and presence.
          </h1>
          <p class="mt-6 max-w-xl text-lg text-[var(--fg-soft)]">
            I build websites, apps, tools and written resources, shaped by a long background in
            temperature metrology, technical communication, training and AI-assisted development.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href={`${base}/projects/`}
              class="rounded-lg bg-[var(--accent)] px-5 py-2.5 text-sm font-medium text-white transition-opacity hover:opacity-90"
            >
              View projects
            </a>
            <a
              href={`${base}/about/`}
              class="rounded-lg border border-[var(--rule)] px-5 py-2.5 text-sm font-medium transition-colors hover:border-[var(--accent)] hover:text-[var(--accent)]"
            >
              Read about me
            </a>
          </div>
        </div>
        <div class="relative flex-shrink-0 self-center">
          {/* Light mode: clean static logo. */}
          <img
            src={`${base}/images/logo/logo-square-transparent.avif`}
            alt="D² Calibrated Ideas"
            width="320"
            height="320"
            class="w-56 sm:w-80 dark:hidden"
          />

          {/* Dark mode: the logo video plays once, then settles to the brand mark. */}
          <div class="relative hidden w-56 sm:w-80 dark:block">
            <video
              id="hero-logo-video"
              src={`${base}/images/about/logo-video.mp4`}
              autoplay
              muted
              playsinline
              preload="auto"
              aria-hidden="true"
              class="block w-full mix-blend-screen"
              style="aspect-ratio: 1 / 1; transition: opacity 0.8s ease-out;"
            ></video>
            {/* Guaranteed end state: fades in when the video stops (or never plays). */}
            <div
              id="hero-logo-reveal"
              class="pointer-events-none absolute inset-0 flex items-center justify-center"
              style="opacity: 0; transition: opacity 0.9s ease-in-out;"
            >
              <div class="rounded-2xl bg-white p-4 shadow-lg shadow-black/20 sm:p-5">
                <img
                  src={`${base}/images/logo/d2-logo-full.png`}
                  alt="D² Calibrated Ideas"
                  width="220"
                  height="220"
                  class="w-36 sm:w-48"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured projects -->
  <section class="mx-auto max-w-5xl px-5 py-16">
    <div class="flex items-baseline justify-between">
      <h2 class="text-2xl sm:text-3xl">Featured work</h2>
      <a href={`${base}/projects/`} class="label-mark hover:text-[var(--accent)]">All projects &rarr;</a>
    </div>
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <!-- What connects the work -->
  <section class="border-y border-[var(--rule)] bg-[var(--bg-soft)]">
    <div class="mx-auto max-w-3xl px-5 py-16">
      <h2 class="text-2xl sm:text-3xl">What connects the work</h2>
      <p class="mt-5 text-lg text-[var(--fg-soft)]">
        Precision measurement, technical writing, AI-assisted tools, web and mobile development,
        training and creative practice are not separate strands. They share one habit: paying close
        attention, then making the result clear and honest.
      </p>
      <p class="mt-4 text-lg text-[var(--fg-soft)]">
        A measurement is only as good as the thinking behind it; a piece of writing only as good as
        what it is willing to say plainly. The same applies to an app or a website. Across all of
        it runs a privacy-first instinct: nothing tracked, nothing collected that need not be.
      </p>
    </div>
  </section>

  <!-- Contact strip -->
  <section class="mx-auto max-w-3xl px-5 py-16 text-center">
    <h2 class="text-2xl sm:text-3xl">Get in touch</h2>
    <p class="mx-auto mt-4 max-w-xl text-lg text-[var(--fg-soft)]">
      I'm always happy to hear from people working on thoughtful digital, technical or creative
      projects. If something here sparks an idea, feel free to get in touch.
    </p>
    <a
      href={`mailto:${SITE.email}`}
      class="mt-6 inline-block rounded-lg border border-[var(--accent)] px-5 py-2.5 text-sm font-medium text-[var(--accent)] transition-colors hover:bg-[var(--accent)] hover:text-white"
    >
      {SITE.email}
    </a>
  </section>

  <script is:inline>
    (() => {
      const video = document.getElementById('hero-logo-video');
      const reveal = document.getElementById('hero-logo-reveal');
      if (!video || !reveal) return;

      let settled = false;
      const settle = () => {
        if (settled) return;
        settled = true;
        video.style.opacity = '0';
        reveal.style.opacity = '1';
      };

      // Respect reduced-motion: skip the animation, show the mark immediately.
      const reduce =
        window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce) {
        settle();
        return;
      }

      // Settle when the clip finishes playing.
      video.addEventListener('ended', settle);

      // Cap the wait to just past the clip length once we know it; this guards
      // against 'ended' never firing on some browsers.
      video.addEventListener('loadedmetadata', () => {
        const ms = (isFinite(video.duration) ? video.duration : 8) * 1000 + 1500;
        setTimeout(settle, ms);
      });

      // Autoplay is frequently blocked on mobile. If play() is rejected, settle
      // straight to the static mark rather than leaving a frozen first frame.
      const p = video.play();
      if (p && typeof p.catch === 'function') p.catch(settle);

      // Absolute safety net.
      setTimeout(settle, 12000);
    })();
  </script>
</BaseLayout>

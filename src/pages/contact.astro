---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, SOCIAL } from '../site';
const social = SOCIAL.filter((s) => s.href && s.label !== 'Email');
---

<BaseLayout
  title="Contact"
  description="Get in touch with David Southworth by email at hello@calibratedideas.com."
>
  <section class="mx-auto max-w-2xl px-5 py-20">
    <p class="label-mark">Contact</p>
    <h1 class="mt-3 text-4xl sm:text-5xl">Say hello</h1>
    <p class="mt-5 text-lg text-[var(--fg-soft)]">
      I'm always happy to hear from people working on thoughtful digital, technical or creative
      projects. If something here sparks an idea, feel free to get in touch.
    </p>

    <a
      href={`mailto:${SITE.email}`}
      class="mt-8 inline-block rounded-lg bg-[var(--accent)] px-5 py-3 text-base font-medium text-white transition-opacity hover:opacity-90"
    >
      {SITE.email}
    </a>

    {
      social.length > 0 && (
        <div class="mt-10">
          <p class="label-mark">Elsewhere</p>
          <ul class="mt-3 flex flex-wrap gap-4">
            {social.map((s) => (
              <li>
                <a href={s.href} class="text-[var(--fg-soft)] hover:text-[var(--accent)]">
                  {s.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )
    }

    <p class="mt-12 text-sm text-[var(--fg-soft)]">
      No contact form, no newsletter, no tracking. Just email.
    </p>
  </section>
</BaseLayout>

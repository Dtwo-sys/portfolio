---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import photo01 from '../assets/images/photography/photo-01.jpg';
import photo02 from '../assets/images/photography/photo-02.jpg';
import photo03 from '../assets/images/photography/photo-03.jpg';
import photo04 from '../assets/images/photography/photo-04.jpg';
import photo05 from '../assets/images/photography/photo-05.jpg';
import photo06 from '../assets/images/photography/photo-06.jpg';
import photo07 from '../assets/images/photography/photo-07.jpg';

const photos = [
  {
    src: photo01,
    alt: 'Long pedestrian tunnel with moving walkways, a traveller with a suitcase walking away down the centre under curved white ceiling panels',
  },
  {
    src: photo02,
    alt: 'Waves breaking over dark rocks on a rugged shoreline under a heavy grey-blue sky',
  },
  {
    src: photo03,
    alt: "Green laser beams criss-crossing between cast-iron columns in the dark interior of Toxteth Reservoir, part of Rita McBride's installation",
  },
  {
    src: photo04,
    alt: 'Miniature railway wagon beside a leaf-strewn path, with an arched viaduct and a golden autumn sunset behind the trees',
  },
  {
    src: photo05,
    alt: 'Aerial view at dusk of a lake winding between wooded hills, with a path curving through parkland in the foreground',
  },
  {
    src: photo06,
    alt: 'Staircase sculpted in translucent red fabric, suspended beneath a gallery ceiling and lit from above',
  },
  {
    src: photo07,
    alt: 'Weathered wooden ribs of an old shipwreck emerging from wet sand at low tide, under a pale overcast sky',
  },
];
---

<BaseLayout
  title="Photography"
  description="Selected photography by David Southworth: coastal light, natural textures, architecture and everyday moments, shot on iPhone."
>
  <section class="mx-auto max-w-5xl px-5 py-12">
    <p class="label-mark">Photography</p>
    <h1 class="mt-3 text-4xl sm:text-5xl">Photography</h1>
    <p class="mt-4 max-w-2xl text-lg text-[var(--fg-soft)]">
      I use photography as a way to notice and capture details that often go unseen: coastal light,
      natural textures, architecture and everyday moments. All shot on iPhone.
    </p>
    <p class="mt-2 text-sm text-[var(--fg-soft)]">
      More recent work on
      <a
        href="https://www.instagram.com/david_j_southworth/"
        class="text-[var(--accent)] underline underline-offset-2"
        >Instagram @david_j_southworth</a
      >.
    </p>

    <div class="mt-10 grid grid-cols-2 gap-3 sm:grid-cols-3">
      {
        photos.map((photo) => (
          <div class="overflow-hidden rounded-lg bg-[var(--bg-soft)] aspect-square">
            <Image
              src={photo.src}
              alt={photo.alt}
              widths={[400, 800]}
              sizes="(max-width: 640px) 50vw, 360px"
              class="h-full w-full object-cover transition-transform duration-300 hover:scale-[1.04]"
            />
          </div>
        ))
      }
    </div>

  </section>
</BaseLayout>

---
import { getCollection, render } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Schema from '../../components/Schema.astro';
import YouTubeFacade from '../../components/YouTubeFacade.astro';
import { SITE } from '../../site';

export const getStaticPaths = (async () => {
  const isProd = import.meta.env.PROD;
  const posts = (await getCollection('posts')).filter((p) => !(isProd && p.data.draft));
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Social-card image: run the hero through the image pipeline so the og:image
// URL always points at a real built asset, as a JPEG for platform compatibility.
const ogImage = post.data.heroImage
  ? (await getImage({ src: post.data.heroImage, width: 1200, format: 'jpeg' })).src
  : undefined;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  ...(ogImage && { image: new URL(ogImage, Astro.site).href }),
  author: {
    '@type': 'Person',
    name: SITE.author,
    url: new URL(`${base}/about/`, Astro.site).href,
  },
  mainEntityOfPage: canonical,
  url: canonical,
};
const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

/*
  Comments via Giscus (GitHub Discussions).
  To activate:
  1. Enable Discussions on github.com/Dtwo-sys/portfolio → Settings → Features → Discussions.
  2. Visit giscus.app, point it at Dtwo-sys/portfolio, create a "Blog Comments" category,
     copy the data-category-id value and paste it below.
  3. Set GISCUS_READY = true.
*/
const GISCUS_READY = false;
const GISCUS_CATEGORY_ID = ''; // paste from giscus.app once Discussions is enabled
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  ogImage={ogImage}
>
  <Schema slot="head" schema={blogPostingSchema} />
  <article class="mx-auto max-w-3xl px-5 py-12">
    <a href={`${base}/blog/`} class="label-mark hover:text-[var(--accent)]">&larr; All posts</a>

    <header class="mt-6 border-b border-[var(--rule)] pb-6">
      <time class="label-mark" datetime={post.data.pubDate.toISOString()}>
        {fmt(post.data.pubDate)}
      </time>
      <h1 class="mt-2 text-4xl sm:text-5xl">{post.data.title}</h1>
      <p class="mt-3 text-lg text-[var(--fg-soft)]">{post.data.description}</p>
    </header>

    {post.data.video && post.data.heroImage ? (
      <div class="mt-8">
        <YouTubeFacade
          videoId={post.data.video}
          poster={post.data.heroImage}
          title={post.data.title}
        />
      </div>
    ) : (
      post.data.heroImage && (
        <Image
          src={post.data.heroImage}
          alt={post.data.heroImageAlt || post.data.title}
          widths={[600, 900, 1200]}
          sizes="(max-width: 768px) 100vw, 720px"
          loading="eager"
          class="mt-8 w-full rounded-xl"
        />
      )
    )}

    <div class="prose-cal mt-8 max-w-[var(--container-prose)]">
      <Content />
    </div>
  </article>

  {GISCUS_READY && (
    <section class="mx-auto max-w-3xl border-t border-[var(--rule)] px-5 py-10">
      <h2 class="mb-6 text-xl">Comments</h2>
      <script
        is:inline
        src="https://giscus.app/client.js"
        data-repo="Dtwo-sys/portfolio"
        data-repo-id="R_kgDOS1G7fQ"
        data-category="Blog Comments"
        data-category-id={GISCUS_CATEGORY_ID}
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="preferred_color_scheme"
        data-lang="en"
        crossorigin="anonymous"
        async
      ></script>
    </section>
  )}
</BaseLayout>

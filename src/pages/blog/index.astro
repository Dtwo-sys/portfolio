---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

const isProd = import.meta.env.PROD;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = (await getCollection('posts'))
  .filter((p) => !(isProd && p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout
  title="Blog"
  description="Writing on technology, astronomy, temperature metrology, creativity and photography."
>
  <section class="mx-auto max-w-3xl px-5 py-12">
    <div class="flex items-baseline justify-between">
      <p class="label-mark">Writing</p>
      <a href={`${base}/rss.xml`} class="label-mark hover:text-[var(--accent)]">RSS</a>
    </div>
    <h1 class="mt-3 text-4xl sm:text-5xl">Blog</h1>
    <p class="mt-4 max-w-2xl text-lg text-[var(--fg-soft)]">
      Occasional writing on technology, astronomy, temperature metrology, creativity and photography.
    </p>

    {
      posts.length === 0 ? (
        <p class="mt-10 text-[var(--fg-soft)]">No posts published yet. Check back soon.</p>
      ) : (
        <ul class="mt-10 divide-y divide-[var(--rule)]">
          {posts.map((post) => (
            <li class="py-5" data-reveal>
              <a
                href={`${base}/blog/${post.id}/`}
                class="group -mx-3 flex gap-4 rounded-lg px-3 py-2 transition-colors hover:bg-[var(--bg-soft)] sm:gap-5"
              >
                {post.data.heroImage && (
                  <div class="flex-none overflow-hidden rounded-lg">
                    <Image
                      src={post.data.heroImage}
                      alt={post.data.heroImageAlt || post.data.title}
                      width={144}
                      height={96}
                      class="h-16 w-24 object-cover transition-transform duration-300 group-hover:scale-[1.04] sm:h-24 sm:w-36"
                    />
                  </div>
                )}
                <div class="min-w-0 flex-1">
                  <time class="label-mark" datetime={post.data.pubDate.toISOString()}>
                    {fmt(post.data.pubDate)}
                  </time>
                  <h2 class="mt-1 text-xl group-hover:text-[var(--accent)]">{post.data.title}</h2>
                  <p class="mt-1 text-[var(--fg-soft)]">{post.data.description}</p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>

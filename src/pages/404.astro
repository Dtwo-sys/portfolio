---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found">
  <section class="mx-auto max-w-2xl px-5 py-28 text-center">
    <p class="label-mark">Error 404</p>
    <h1 class="mt-3 text-4xl sm:text-5xl">Off the scale</h1>
    <p class="mt-4 text-lg text-[var(--fg-soft)]">
      That page isn't here. The reading is out of range.
    </p>
    <a
      href={import.meta.env.BASE_URL}
      class="mt-8 inline-block rounded-lg bg-[var(--accent)] px-5 py-2.5 text-sm font-medium text-white transition-opacity hover:opacity-90"
    >
      Back to home
    </a>
  </section>
</BaseLayout>

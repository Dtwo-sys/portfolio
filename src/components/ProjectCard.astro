---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  /** Card title heading level; pages whose cards sit directly under the h1 pass 'h2'. */
  headingLevel?: 'h2' | 'h3';
}

const { project, headingLevel = 'h3' } = Astro.props;
const Heading = headingLevel;
const { data } = project;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = `${base}/projects/${project.id}/`;
const tags = data.categories.slice(0, 3);
---

<div class="project-card group relative h-full">
  <a
    href={href}
    class="flex h-full flex-col overflow-hidden rounded-lg border border-[var(--rule)] bg-[var(--bg-soft)] transition-transform duration-200 hover:-translate-y-0.5 focus-visible:-translate-y-0.5"
  >
    <div class="relative aspect-[16/10] overflow-hidden bg-[var(--bg)]">
      {
        data.image ? (
          <Image
            src={data.image}
            alt={data.imageAlt || data.title}
            widths={[400, 800]}
            sizes="(max-width: 640px) 100vw, 400px"
            class="h-full w-full object-cover object-top transition-transform duration-300 group-hover:scale-[1.03]"
          />
        ) : (
          <div class="bg-graph flex h-full w-full items-center justify-center">
            <span class="label-mark">{data.type}</span>
          </div>
        )
      }
    </div>

    <div class="flex flex-1 flex-col gap-2 p-5">
      <div class="flex items-baseline justify-between gap-3">
        <Heading class="font-display text-xl group-hover:text-[var(--accent)]">{data.title}</Heading>
        <span class="label-mark shrink-0">{data.year}</span>
      </div>
      <p class="label-mark">{data.type}</p>
      <p class="text-sm text-[var(--fg-soft)]">{data.summary}</p>
      {
        tags.length > 0 && (
          <ul class="mt-auto flex flex-wrap gap-2 pt-3">
            {tags.map((t) => (
              <li class="rounded-full border border-[var(--rule)] px-2.5 py-0.5 text-xs text-[var(--fg-soft)]">
                {t}
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </a>
</div>

---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { data } = project;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = `${base}/projects/${project.id}/`;
const tags = data.categories.slice(0, 3);
---

<a
  href={href}
  class="group flex flex-col overflow-hidden rounded-lg border border-[var(--rule)] bg-[var(--bg-soft)] transition-transform duration-200 hover:-translate-y-0.5 focus-visible:-translate-y-0.5"
>
  <div class="relative aspect-[16/10] overflow-hidden bg-[var(--bg)]">
    {
      data.image ? (
        <Image
          src={data.image}
          alt={data.imageAlt || data.title}
          widths={[400, 800]}
          sizes="(max-width: 640px) 100vw, 400px"
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
        />
      ) : (
        <div class="bg-graph flex h-full w-full items-center justify-center">
          <span class="label-mark">{data.type}</span>
        </div>
      )
    }
    <span class="label-mark absolute left-3 top-3 rounded bg-[var(--bg)]/85 px-2 py-1">
      {data.year}
    </span>
  </div>

  <div class="flex flex-1 flex-col gap-2 p-5">
    <div class="flex items-baseline justify-between gap-3">
      <h3 class="font-display text-xl group-hover:text-[var(--accent)]">{data.title}</h3>
    </div>
    <p class="label-mark">{data.type}</p>
    <p class="text-sm text-[var(--fg-soft)]">{data.summary}</p>
    {
      tags.length > 0 && (
        <ul class="mt-auto flex flex-wrap gap-2 pt-3">
          {tags.map((t) => (
            <li class="rounded-full border border-[var(--rule)] px-2.5 py-0.5 text-xs text-[var(--fg-soft)]">
              {t}
            </li>
          ))}
        </ul>
      )
    }
  </div>
</a>

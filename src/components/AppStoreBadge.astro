---
/*
  Text-based App Store / Play Store badges. The official artwork is not bundled
  yet; drop the official badge SVGs into /public/images/badges/ and swap these
  out when available (brief §11a). Until then these accessible links stand in.
*/
interface Props {
  appStore?: string;
  playStore?: string;
}
const { appStore, playStore } = Astro.props;
---

<div class="flex flex-wrap gap-3">
  {
    appStore && (
      <a
        href={appStore}
        class="inline-flex items-center gap-2 rounded-lg border border-[var(--fg)] bg-[var(--fg)] px-4 py-2 text-sm text-[var(--bg)] transition-opacity hover:opacity-90"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M16.4 1.8c.1 1-.3 2-1 2.8-.7.8-1.8 1.4-2.8 1.3-.1-1 .4-2 1-2.7.7-.8 1.9-1.4 2.8-1.4z" />
          <path d="M19.6 17.3c-.5 1.2-.8 1.7-1.5 2.7-1 1.4-2.3 3.1-4 3.1-1.5 0-1.9-1-3.9-1-2 0-2.4 1-3.9 1-1.7 0-3-1.6-3.9-3C1.8 18.7 1.2 14.5 2.7 11.9c.9-1.6 2.5-2.6 4.2-2.6 1.6 0 2.6 1 3.9 1 1.3 0 2-1 3.9-1 1.5 0 3 .8 4 2.2-3.5 1.9-3 6.8.9 7.8z" />
        </svg>
        <span>Download on the App Store</span>
      </a>
    )
  }
  {
    playStore && (
      <a
        href={playStore}
        class="inline-flex items-center gap-2 rounded-lg border border-[var(--fg)] bg-[var(--fg)] px-4 py-2 text-sm text-[var(--bg)] transition-opacity hover:opacity-90"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M3.6 2.3c-.2.2-.3.5-.3.9v17.6c0 .4.1.7.3.9l.1.1L13 12v-.1L3.7 2.2z" />
          <path d="M16.5 15.3 13 12v-.1l3.5-3.4.1.1 4.1 2.3c1.2.7 1.2 1.8 0 2.5z" />
        </svg>
        <span>Get it on Google Play</span>
      </a>
    )
  }
</div>

---
/*
  Privacy-respecting YouTube embed. The page ships only a locally hosted
  poster image, so it makes no request to Google on load. The
  youtube-nocookie.com iframe is created only when the visitor clicks
  play. This keeps the site's no-third-party-scripts, no-tracking
  promise intact while still letting a video be watched in place.
*/
import { Image } from 'astro:assets';

interface Props {
  /** The 11-character YouTube video id. */
  videoId: string;
  /** Locally hosted poster (imported image), so nothing loads from Google up front. */
  poster: ImageMetadata;
  /** Used for the accessible label and the iframe title. */
  title: string;
}
const { videoId, poster, title } = Astro.props;
---

<div
  class="yt-facade relative overflow-hidden rounded-xl border border-[var(--rule)]"
  data-video-id={videoId}
  data-title={title}
>
  <button type="button" class="yt-facade-btn group" aria-label={`Play video: ${title}`}>
    <Image
      src={poster}
      alt={title}
      widths={[640, 1000, 1280]}
      sizes="(max-width: 768px) 100vw, 720px"
      class="block h-full w-full object-cover"
    />
    <span class="yt-play" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="34" height="34" fill="currentColor">
        <path d="M8 5v14l11-7z"></path>
      </svg>
    </span>
  </button>
</div>

<style>
  .yt-facade {
    aspect-ratio: 16 / 9;
    background: #16181a;
  }
  .yt-facade-btn {
    display: block;
    width: 100%;
    height: 100%;
    padding: 0;
    border: 0;
    cursor: pointer;
    background: none;
  }
  .yt-play {
    position: absolute;
    inset: 0;
    margin: auto;
    display: grid;
    place-items: center;
    width: 76px;
    height: 76px;
    padding-left: 4px; /* optically centre the triangle */
    color: #f5f2ec;
    background: rgb(2 38 93 / 0.78); /* brand ink */
    border-radius: 9999px;
    transition:
      transform 0.18s ease,
      background-color 0.18s ease;
  }
  .yt-facade-btn:hover .yt-play,
  .yt-facade-btn:focus-visible .yt-play {
    transform: scale(1.08);
    background: rgb(2 38 93 / 0.92);
  }
  /* The created iframe fills the box. */
  .yt-facade :global(iframe) {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .yt-play {
      transition: none;
    }
  }
</style>

<script>
  // Swap the poster for the real player on click. No third-party request
  // happens until this fires.
  for (const el of document.querySelectorAll<HTMLElement>('.yt-facade')) {
    const btn = el.querySelector('.yt-facade-btn');
    btn?.addEventListener('click', () => {
      const id = el.dataset.videoId;
      const title = el.dataset.title ?? 'YouTube video';
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
      iframe.title = title;
      iframe.allow =
        'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.allowFullscreen = true;
      el.replaceChildren(iframe);
    });
  }
</script>

---
import { SITE, NAV, SOCIAL } from '../site';
import D2Mark from './D2Mark.astro';
const year = new Date().getFullYear();
const social = SOCIAL.filter((s) => s.href);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="mt-24 border-t border-[var(--rule)]">
  <div class="rule-ticks"></div>
  <div class="mx-auto max-w-5xl px-5 py-6">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
      <div class="max-w-sm">
        <a
          href={`${base}/`}
          class="inline-flex items-center gap-2"
          aria-label="Calibrated Ideas, home"
        >
          {/* Same inline mark as the header and hero; the link's aria-label
              names the destination, so the mark itself is decorative. */}
          <D2Mark id="footer" label="" class="h-12 w-auto shrink-0" />
          <span class="font-display text-lg font-semibold tracking-tight">{SITE.name}</span>
        </a>
        <p class="mt-3 text-sm text-[var(--fg-soft)]">
          Exact things, inexact things, and the gap between them.
        </p>
      </div>

      <nav
        aria-label="Footer"
        class="flex flex-wrap gap-x-5 gap-y-2 text-sm sm:flex-col sm:gap-2"
      >
        {NAV.map((item) => (
          <a href={`${base}${item.href}`} class="text-[var(--fg-soft)] hover:text-[var(--accent)]">
            {item.label}
          </a>
        ))}
      </nav>

      <div class="flex flex-wrap gap-x-5 gap-y-2 text-sm sm:flex-col sm:gap-2">
        {social.map((s) => (
          <a href={s.href} class="text-[var(--fg-soft)] hover:text-[var(--accent)]">
            {s.label}
          </a>
        ))}
        <a href={`${base}/legal/`} class="text-[var(--fg-soft)] hover:text-[var(--accent)]">
          Legal and privacy
        </a>
      </div>
    </div>

    <p class="label-mark mt-6">© {year} {SITE.author}</p>
  </div>
</footer>

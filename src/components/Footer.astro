---
import { SITE, NAV, SOCIAL } from '../site';
const year = new Date().getFullYear();
const social = SOCIAL.filter((s) => s.href);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="mt-24 border-t border-[var(--rule)]">
  <div class="rule-ticks"></div>
  <div class="mx-auto max-w-5xl px-5 py-6">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
      <div class="max-w-sm">
        <a href={`${base}/`} class="inline-block" aria-label="Calibrated Ideas, home">
          <img
            src={`${base}/images/logo/d2-logo-transparent.webp`}
            alt="D² Calibrated Ideas"
            width="180"
            height="60"
            class="dark:brightness-0 dark:invert"
          />
        </a>
        <p class="mt-3 text-sm text-[var(--fg-soft)]">
          The portfolio of {SITE.author}. Made with precision and presence; no tracking, no
          analytics.
        </p>
      </div>

      <nav aria-label="Footer" class="flex flex-col gap-2 text-sm">
        {NAV.map((item) => (
          <a href={`${base}${item.href}`} class="text-[var(--fg-soft)] hover:text-[var(--accent)]">
            {item.label}
          </a>
        ))}
      </nav>

      <div class="flex flex-col gap-2 text-sm">
        {social.map((s) => (
          <a href={s.href} class="text-[var(--fg-soft)] hover:text-[var(--accent)]">
            {s.label}
          </a>
        ))}
        <a href={`${base}/legal/`} class="text-[var(--fg-soft)] hover:text-[var(--accent)]">
          Legal and privacy
        </a>
      </div>
    </div>

    <p class="label-mark mt-6">© {year} {SITE.author}</p>
  </div>
</footer>
